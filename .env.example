# Copy this file to .env (or .env.local) and fill in real values.
# .env is gitignored — never commit your actual secrets.

# Long random string used to sign admin login JWTs.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# Admin login credentials
ADMIN_USERNAME=admin

# bcrypt hash of the admin password — NOT the plain password.
# Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password-here', 12))"
ADMIN_PASSWORD_HASH=
